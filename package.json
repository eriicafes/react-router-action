{
  "name": "react-router-action",
  "version": "2.0.0",
  "description": "Typesafe react router actions",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "release": "pnpm run build && changeset publish",
    "watch": "vitest",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "router",
    "action",
    "typed-action",
    "route-action",
    "rpc"
  ],
  "author": "Eric Afes <eriicafes@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriicafes/react-router-action.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-router": ">=7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/react": "18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}